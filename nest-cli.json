{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "monorepo": true,
  "root": "src",
  "compilerOptions": {
    "tsConfigPath": "tsconfig.json",
    "webpack": false,
    "deleteOutDir": true,
    "assets": [{ "include": "**/*.json", "watchAssets": true }]
  },
  "projects": {
    "main-api": {
      "type": "application",
      "root": "src",
      "entryFile": "main",
      "sourceRoot": "src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json",
        "outDir": "dist/main-api"
      }
    },
    "scheduler": {
      "type": "application",
      "root": "apps/scheduler",
      "entryFile": "main",
      "sourceRoot": "apps/scheduler/src",
      "compilerOptions": {
        "tsConfigPath": "apps/scheduler/tsconfig.json",
        "outDir": "dist/scheduler"
      }
    },
    "call-processor": {
      "type": "application",
      "root": "apps/call-processor",
      "entryFile": "main",
      "sourceRoot": "apps/call-processor/src",
      "compilerOptions": {
        "tsConfigPath": "apps/call-processor/tsconfig.json",
        "outDir": "dist/call-processor"
      }
    },
    "webhook-handler": {
      "type": "application",
      "root": "apps/webhook-handler",
      "entryFile": "main",
      "sourceRoot": "apps/webhook-handler/src",
      "compilerOptions": {
        "tsConfigPath": "apps/webhook-handler/tsconfig.json",
        "outDir": "dist/webhook-handler"
      }
    }
  }
}
