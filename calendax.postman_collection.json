            ],
            "url": {
              "raw": "{{baseUrl}}/admin/pages/side-bar",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "pages", "side-bar"]
            },
            "description": "Requires ADMIN role. Returns pages accessible for sidebar."
          }
        },
        {
          "name": "Create Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
