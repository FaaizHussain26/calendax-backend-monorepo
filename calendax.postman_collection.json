            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@calendax.com\",\n  \"password\": \"Admin@1234\",\n  \"role\": \"admin\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin",
              "host": ["{{baseUrl}}"],
              "path": ["admin"]
