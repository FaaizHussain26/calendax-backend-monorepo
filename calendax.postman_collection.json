{
  "info": {
    "name": "Calendax API",
    "_postman_id": "calendax-api-collection",
    "description": "Complete API collection for Calendax multi-tenant server",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string",
      "description": "JWT token for admin (auto-set after admin login)"
    },
    {
      "key": "tenantToken",
      "value": "",
      "type": "string",
      "description": "JWT token for tenant user (auto-set after tenant login)"
    },
    {
      "key": "tenantId",
      "value": "",
      "type": "string",
      "description": "Tenant slug used in x-tenant-id header"
    },
    {
      "key": "adminId",
      "value": "",
      "type": "string"
    },
    {
      "key": "pageId",
      "value": "",
      "type": "string"
    },
    {
      "key": "tenantRecordId",
      "value": "",
      "type": "string"
    },
    {
      "key": "permissionGroupId",
      "value": "",
      "type": "string"
    },
    {
      "key": "permissionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "roleId",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            }
          }
        }
      ]
    },
    {
      "name": "Admin - Auth",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('adminToken', res.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@calendax.com\",\n  \"password\": \"Admin@1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/login",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "login"]
            },
            "description": "Public route. Saves accessToken to {{adminToken}}."
          }
        }
      ]
    },
    {
      "name": "Admin - Admins",
      "item": [
        {
          "name": "Get All Admins",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin",
              "host": ["{{baseUrl}}"],
              "path": ["admin"]
            }
          }
        },
        {
          "name": "Get Admin By ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
